# Enruta todas las peticiones de /api/* al router index.php
RewriteEngine On
RewriteBase /api/

# No reescribir archivos o carpetas que existen físicamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^(.*)$ index.php?path=/$1 [QSA,L]

# Proteger archivos de configuración sensibles
<FilesMatch "config\.(local|sample)\.php$">
    Require all denied
</FilesMatch>
